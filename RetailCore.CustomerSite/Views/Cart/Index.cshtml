@model RetailCore.Shared.ViewModels.CartPageViewModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Your Cart";
    var imageBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? "";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2>

    @if (Model.CartData.Items != null && Model.CartData.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="cart-table">
                                <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 50px;">
                                        <input class="form-check-input" type="checkbox" id="check-all" onclick="toggleAll(this)">
                                    </th>
                                    <th class="py-3">Product</th>
                                    <th class="py-3">Price</th>
                                    <th class="py-3">Quantity</th>
                                    <th class="py-3 text-end pe-4">Total</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var item in Model.CartData.Items)
                                {
                                    var thumbUrl = $"{imageBaseUrl}/{item.ProductSummary.ThumbnailUrl}";
                                    <tr id="row-@item.Id">
                                        <td class="ps-4">
                                            <input class="form-check-input item-checkbox" type="checkbox" 
                                                   data-id="@item.Id" 
                                                   data-total="@item.Total" 
                                                   onclick="calculateSummary()">
                                        </td>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@thumbUrl" class="rounded me-3" style="width: 70px; height: 70px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-1 fw-bold">@item.ProductSummary.Name</h6>
                                                    <div class="small text-muted">
                                                        @foreach (var attr in item.SelectedAttributes)
                                                        {
                                                            <span class="me-2">@attr.Name: <strong>@attr.Value</strong></span>
                                                        }
                                                    </div>
                                                    <button class="btn btn-sm text-danger p-0 mt-1" onclick="removeItem('@item.Id')">
                                                        <i class="bi bi-trash me-1"></i>Remove
                                                    </button>
                                                </div>
                                            </div>
                                        </td>
                                        <td>$<span class="item-price">@item.Price.ToString("N2")</span></td>
                                        <td>
                                            <div class="input-group input-group-sm" style="width: 110px;">
                                                <button class="btn btn-outline-secondary" onclick="updateQty('@item.Id', -1)">-</button>
                                                <input type="text" class="form-control text-center bg-white" value="@item.Quantity" readonly id="qty-@item.Id">
                                                <button class="btn btn-outline-secondary" onclick="updateQty('@item.Id', 1)">+</button>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4 fw-bold">
                                            $<span id="total-@item.Id">@item.Total.ToString("N2")</span>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span id="grand-total-sub" class="fw-bold">$0.00</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span>Shipping</span>
                            <span class="text-success">Free</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold">Total</span>
                            <span id="grand-total" class="h5 fw-bold text-primary">$0.00</span>
                        </div>
                        <button class="btn btn-primary w-100 btn-lg rounded-pill" disabled id="btn-checkout">
                            Checkout <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h3 class="mt-4">Your cart is empty</h3>
            <a href="/" class="btn btn-primary mt-3 px-4 rounded-pill">Go Shopping</a>
        </div>
    }
</div>

<script>
    async function updateQty(cartItemId, change) {
        const qtyInput = document.getElementById(`qty-${cartItemId}`);
        let newQty = parseInt(qtyInput.value) + change;

        // Nếu newQty < 0 thì không làm gì cả, nhưng 0 thì cho phép để xóa
        if (newQty < 0) return;

        // Nếu newQty == 0, hiện confirm để xác nhận xóa cho chắc chắn (giống như nút Remove)
        if (newQty === 0) {
            const confirmDelete = confirm("Bạn có muốn xóa sản phẩm này khỏi giỏ hàng?");
            if (!confirmDelete) return;
        }

        const payload = {
            cartItemId: cartItemId,
            quantity: newQty,
            productAttributeId: null // Giữ nguyên Attribute cũ
        };

        try {
            const response = await fetch('/Cart/Update', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                // Nếu số lượng mới là 0, thực hiện hiệu ứng xóa dòng thay vì reload
                if (newQty === 0) {
                    const row = document.getElementById(`row-${cartItemId}`);
                    row.style.transition = "all 0.5s ease";
                    row.style.opacity = "0";
                    row.style.transform = "translateX(50px)";

                    setTimeout(() => {
                        row.remove();
                        calculateSummary(); // Tính lại tiền
                        // Nếu hết sạch hàng thì reload để hiện màn hình "Empty Cart"
                        if (document.querySelectorAll('.item-checkbox').length === 0) {
                            location.reload();
                        }
                    }, 500);
                    showToast("Đã xóa sản phẩm");
                } else {
                    // Nếu update số lượng dương, reload để lấy dữ liệu total mới từ server
                    location.reload();
                }
            } else {
                showToast("Không thể cập nhật số lượng", "error");
            }
        } catch (e) {
            showToast("Lỗi kết nối", "error");
        }
    }
    
    async function removeItem(cartItemId) {
        if (!confirm("Are you sure?")) return;

        try {
            const response = await fetch(`/Cart/Remove/${cartItemId}`, { method: 'DELETE' });

            if (response.status === 204 || response.ok) {
                const row = document.getElementById(`row-${cartItemId}`);
                row.style.transition = "all 0.5s ease";
                row.style.opacity = "0";
                row.style.transform = "translateX(50px)";

                setTimeout(() => {
                    row.remove();
                    if (document.querySelectorAll('#cart-table tbody tr').length === 0) {
                        location.reload();
                    }
                }, 500);

                showToast("Item removed");
            }
        } catch (e) {
            showToast("Cannot remove item", "error");
        }
    }

    function calculateSummary() {
        let grandTotal = 0;
        const checkedItems = document.querySelectorAll('.item-checkbox:checked');

        checkedItems.forEach(item => {
            // Lấy giá trị total của dòng đó (đã được update khi tăng/giảm số lượng)
            const itemTotal = parseFloat(item.getAttribute('data-total'));
            grandTotal += itemTotal;
        });

        // Cập nhật lên UI Summary
        const formattedTotal = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(grandTotal);
        document.getElementById('grand-total-sub').innerText = formattedTotal;
        document.getElementById('grand-total').innerText = formattedTotal;

        // Active/Deactive nút Checkout nếu không có món nào được chọn
        const checkoutBtn = document.querySelector('.btn-primary.w-100');
        checkoutBtn.disabled = checkedItems.length === 0;
    }

    // Hàm chọn/bỏ chọn tất cả
    function toggleAll(source) {
        const checkboxes = document.querySelectorAll('.item-checkbox');
        checkboxes.forEach(cb => cb.checked = source.checked);
        calculateSummary();
    }

    document.addEventListener('DOMContentLoaded', () => {
        calculateSummary();
    });
</script>