@model RegisterRequest
@{
    ViewData["Title"] = "Create Account";
    Layout = "_AuthLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <!-- Tiêu đề -->
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-primary">Get Started</h3>
                        <p class="text-muted">Create your Retail Core account to continue.</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold small text-uppercase"></label>
                            <input asp-for="FullName" class="form-control form-control-lg fs-6" placeholder="First Name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold small text-uppercase"></label>
                            <input asp-for="Email" class="form-control form-control-lg fs-6" placeholder="name@company.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold small text-uppercase"></label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg fs-6" placeholder="Create a password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold small text-uppercase"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg fs-6" placeholder="Repeat your password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-primary btn-lg fs-6 fw-bold shadow-sm">Create Account</button>
                        </div>

                        <p class="text-center text-muted x-small mb-4">
                            By signing up, you agree to our 
                            <a href="#" class="text-decoration-none">Terms of Service</a> and 
                            <a href="#" class="text-decoration-none">Privacy Policy</a>.
                        </p>

                        <!-- Link ngược lại Login -->
                        <div class="text-center border-top pt-3">
                            <p class="text-muted small mb-0">
                                Already have an account? 
                                <a asp-controller="Auth" asp-action="Login" class="text-primary fw-bold text-decoration-none">Log in here</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}