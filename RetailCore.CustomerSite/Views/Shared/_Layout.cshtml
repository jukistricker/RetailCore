<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - RetailCore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header>
    @await Html.PartialAsync("_Navbar")
</header>

<main role="main" class="container my-4">
    @RenderBody()
</main>

<footer class="footer mt-auto py-4">
    <div class="container text-center">
        <div class="row">
            <div class="col-md-4">
                <h5>About Us</h5>
                <p class="small">High quality tech products for everyone.</p>
            </div>
            <div class="col-md-4">
                <h5>Links</h5>
                <ul class="list-unstyled">
                    <li><a href="/Contact">Contact</a></li>
                    <li><a href="/Privacy">Privacy Policy</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h5>Follow Us</h5>
                <i class="bi bi-facebook mx-2"></i>
                <i class="bi bi-github mx-2"></i>
            </div>
        </div>
        <hr>
        <span>&copy; 2026 - RetailCore Ecommerce</span>
    </div>
</footer>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const toggleBtn = document.getElementById('theme-toggle');
    const themeIcon = document.getElementById('theme-icon');
    const root = document.documentElement;

    const applyTheme = (theme) => {
        root.setAttribute('data-theme', theme);
        themeIcon.className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        localStorage.setItem('theme', theme);
    };

    const savedTheme = localStorage.getItem('theme') || 'light';
    applyTheme(savedTheme);

    toggleBtn.addEventListener('click', () => {
        const newTheme = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(newTheme);
    });
</script>
<script>
    (function() {
        const { fetch: originalFetch } = window;

        window.fetch = async (...args) => {
            let [resource, config] = args;
            if (!config) config = {};

            config.credentials = 'include';

            try {
                const response = await originalFetch(resource, config);

                const isRefreshRequest = typeof resource === 'string' && resource.includes('/Auth/RefreshToken');
                
                if (response.status === 401 && !isRefreshRequest) {
                    const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                    window.location.href = `/Auth/Login?ReturnUrl=${returnUrl}`;
                }

                return response;
            } catch (error) {
                return Promise.reject(error);
            }
        };

        async function performRefreshToken() {
            try {
                const response = await fetch('/Auth/RefreshToken', { 
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' } // Giúp server nhận diện là AJAX
                });
                
                if (response.ok) {
                    console.log("Token refreshed at: " + new Date().toLocaleTimeString());
                }
            } catch (error) {
                console.error("Token refresh heartbeat failed.");
            }
        }

        setInterval(performRefreshToken, 600000);
        
        performRefreshToken(); 

    })();
</script>
@await RenderSectionAsync("Scripts", false)
</body>
</html>