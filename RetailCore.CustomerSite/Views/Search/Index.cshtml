@using RetailCore.Shared.DTOs
@model PagingResponse<ProductSummaryResponse>

@{
    ViewData["Title"] = "Search Results";
    var keyword = Context.Request.Query["q"];
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            @if (!string.IsNullOrEmpty(keyword))
            {
                <text>Results for "@keyword"</text>
            }
            else
            {
                <text>All Products</text>
            }
        </h2>
        <span class="text-muted">Found @Model.TotalCount products</span>
    </div>

    @if (Model.Items != null && Model.Items.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model.Items)
            {
                <div class="col">
                    @await Html.PartialAsync("_ProductCardPartial", product)
                </div>
            }
        </div>

        <!-- Phân trang (Pagination) -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { q = keyword, categoryId = Context.Request.Query["categoryId"], pageNumber = i })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-search-heart display-1 text-muted"></i>
            <p class="mt-3 fs-5">Sorry, we couldn't find any products matching your search.</p>
            <a href="/" class="btn btn-primary mt-2">Back to Home</a>
        </div>
    }
</div>